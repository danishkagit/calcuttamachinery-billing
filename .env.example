# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB — use local or MongoDB Atlas
# Local: mongodb://localhost:27017/gstbilling
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/gstbilling
MONGODB_URI=mongodb://localhost:27017/gstbilling

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-change-this
